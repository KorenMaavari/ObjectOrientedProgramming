Object subclass: #Monom	instanceVariableNames: 'exp coef'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP1'!!Monom methodsFor: 'ArithmeticOperation' stamp: 'Koren 6/15/2024 14:17'!derivative	| res |	res := Monom new.	((self coef = 0) or: [self exp = 0])		ifTrue: [			^res		]		ifFalse: [			res coef: (self coef * self exp); exp: (self exp - 1).			^res		]! !!Monom methodsFor: 'initialize-release' stamp: 'Koren 6/15/2024 14:17'!initialize	coef := 0.	exp := 0.! !!Monom methodsFor: 'Setters' stamp: 'Koren 6/15/2024 14:16'!coef: anInteger	(anInteger isKindOf: Integer)		ifTrue: [coef := anInteger]		ifFalse: [self error: 'invalid input'].! !!Monom methodsFor: 'Setters' stamp: 'Koren 6/15/2024 14:17'!exp: anInteger	(anInteger isInteger and: [anInteger >= 0])		ifTrue: [exp := anInteger]		ifFalse: [self error: 'invalid input'].! !!Monom methodsFor: 'Getters' stamp: 'Koren 6/15/2024 14:16'!coef	^coef! !!Monom methodsFor: 'Getters' stamp: 'Koren 6/15/2024 14:17'!exp	^exp! !Object subclass: #PolyStream	instanceVariableNames: 'block'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP1'!!PolyStream methodsFor: 'Getters' stamp: 'Koren 6/15/2024 14:50'!block	^block! !!PolyStream methodsFor: 'initialize-release' stamp: 'Koren 6/15/2024 14:18'!initialize	block := [:x|]! !!PolyStream methodsFor: 'Ops' stamp: 'Koren 6/15/2024 14:54'!add: aPolyStream	(aPolyStream isKindOf: PolyStream)		ifFalse: [self error: 'invalid input']		ifTrue: [			block := [:x | (block value: x) + (aPolyStream block value: x)]		]! !!PolyStream methodsFor: 'Ops' stamp: 'Koren 6/15/2024 14:47'!addCoef: coef withExp: exp	((coef isKindOf: Integer) and: [(exp isKindOf: Integer) and: [exp>=0]])		ifFalse: [self error: 'invalid input']		ifTrue: [			block := [:x | (block value: x) + (coef * (x raisedTo: exp))]		]! !!PolyStream methodsFor: 'Ops' stamp: 'Koren 6/15/2024 15:29'!eval: anInteger	(anInteger isKindOf: Integer)		ifFalse: [self error: 'invalid input']		ifTrue: [^(block value: anInteger)].! !!PolyStream methodsFor: 'Ops' stamp: 'Koren 6/15/2024 15:26'!filter: aSet	block := [:x |		|filteredX|		filteredX := 0.		aSet do: [:element | (filteredX := filteredX + 0) at: element ifAbsent: [filteredX + (block value: x)]].		^filteredX	].! !!PolyStream methodsFor: 'Ops' stamp: 'Koren 6/15/2024 15:03'!multiplyBy: anInteger	(anInteger isKindOf: Integer)		ifFalse: [self error: 'invalid input']		ifTrue: [			block := [:x | anInteger * (block value: x)]		]! !!PolyStream methodsFor: 'Ops' stamp: 'Koren 6/15/2024 15:01'!substitute: anInteger	((anInteger isKindOf: Integer) and: [anInteger ~= 0])		ifFalse: [self error: 'invalid input']		ifTrue: [			block := [:x | block value: (anInteger * x)]		]! !Object subclass: #Polynom	instanceVariableNames: 'monoms'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP1'!!Polynom methodsFor: 'Ops' stamp: 'Koren 6/15/2024 14:17'!add: aPolynom	(aPolynom isKindOf: Polynom)		ifFalse: [self error: 'invalid input']		ifTrue: [			|res|			res := Polynom new.			monoms do: [:element | res addMonom: element]. "Copy the self polynom into the temp polynom"			aPolynom monoms do: [:element | res addMonom: element]. "Add the input polynom into the temo polynom"			^res		]! !!Polynom methodsFor: 'Ops' stamp: 'Koren 6/15/2024 14:17'!addMonom: aMonom	|tempExp counter tempMonom|	(aMonom isKindOf: Monom)		ifFalse: [self error: 'invalid input'] "error handling"				ifTrue: [ "if the input is OK"			(aMonom coef = 0)				ifFalse: "coef is not 0"				[ 					counter := 0.					tempExp := aMonom exp.					monoms do: [:element | (element exp = tempExp) ifTrue: [counter := counter + 1]. ].										(counter = 0) "does not exist"						ifTrue: 						[							tempMonom := Monom new.							tempMonom exp: tempExp.							tempMonom coef: (aMonom coef).							monoms add: tempMonom.						]											ifFalse: "exists"						[ 							monoms do:[:element | (element exp = tempExp) ifTrue: [element coef: (element coef + aMonom coef)]]						]				]		].! !!Polynom methodsFor: 'Ops' stamp: 'Koren 6/15/2024 14:17'!asDictionary	|res|	res := Dictionary new.	monoms do: [:element | 		(element coef = 0)			ifTrue: ["NOP"]			ifFalse: [				res at: (element exp) put: element coef].			].	^res! !!Polynom methodsFor: 'Ops' stamp: 'Koren 6/15/2024 14:17'!derivative	|res|	res := Polynom new.	monoms do: [:element | res addMonom: (element derivative)].	^res! !!Polynom methodsFor: 'Ops' stamp: 'Koren 6/15/2024 14:18'!eval: anInteger	(anInteger isKindOf: Integer)		ifFalse: [self error: 'invalid input']		ifTrue: [			^monoms inject: 0 into: [:sum :element | sum + (element coef * (anInteger raisedTo: element exp))]		].! !!Polynom methodsFor: 'Ops' stamp: 'Koren 6/15/2024 14:18'!multiplyByMonom: aMonom	(aMonom isKindOf: Monom)		ifFalse: [self error: 'invalid input']		ifTrue:		[			monoms do: [:element | element coef: (element coef * aMonom coef); exp: (element exp + aMonom exp)]		].! !!Polynom methodsFor: 'Getters' stamp: 'Koren 6/15/2024 14:17'!monoms	^monoms! !!Polynom methodsFor: 'initialize-release' stamp: 'Koren 6/15/2024 14:17'!initialize	monoms := LinkedList new.! !