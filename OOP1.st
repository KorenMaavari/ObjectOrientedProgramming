Object subclass: #Monom	instanceVariableNames: 'exp coef'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP1'!!Monom methodsFor: 'ArithmeticOperation' stamp: 'Koren 6/15/2024 11:34'!derivative	| res |	res := Monom new.	((self coef = 0) or: [self exp = 0])		ifTrue: [			^res		]		ifFalse: [			res coef: (self coef * self exp); exp: (self exp - 1).			^res		]! !!Monom methodsFor: 'Setters' stamp: 'Koren 6/11/2024 11:16'!coef: anInteger	(anInteger isKindOf: Integer)		ifTrue: [coef := anInteger]		ifFalse: [self error: 'invalid input'].! !!Monom methodsFor: 'Setters' stamp: 'Koren 6/11/2024 11:01'!exp: anInteger	(anInteger isInteger and: [anInteger >= 0])		ifTrue: [exp := anInteger]		ifFalse: [self error: 'invalid input'].! !!Monom methodsFor: 'Getters' stamp: 'Koren 6/11/2024 11:02'!coef	^coef! !!Monom methodsFor: 'Getters' stamp: 'Koren 6/11/2024 10:49'!exp	^exp! !Object subclass: #Polynom	instanceVariableNames: 'monoms'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP1'!!Polynom methodsFor: 'Ops' stamp: 'Koren 6/11/2024 13:18'!addMonom: aMonom	|tempExp counter tempMonom|	(aMonom isKindOf: Monom)		ifFalse: [self error: 'invalid input'] "error handling"				ifTrue: [ "if the input is OK"			(aMonom coef = 0)				ifFalse: "coef is not 0"				[ 					counter := 0.					tempExp := aMonom exp.					monoms do: [:element | (element exp = tempExp) ifTrue: [counter := counter + 1]. ].										(counter = 0) "does not exist"						ifTrue: 						[							tempMonom := Monom new.							tempMonom exp: tempExp.							tempMonom coef: (aMonom coef).							monoms add: tempMonom.						]											ifFalse: "exists"						[ 							monoms do:[:element | (element exp = tempExp) ifTrue: [element coef: (element coef + aMonom coef)]]						]				]		].! !!Polynom methodsFor: 'Ops' stamp: 'Koren 6/15/2024 12:01'!asDictionary	|res|	res := Dictionary new.	monoms do: [:element | 		(element coef = 0)			ifTrue: ["NOP"]			ifFalse: [				res at: (element exp) put: element coef].			].	^res! !!Polynom methodsFor: 'Ops' stamp: 'Koren 6/11/2024 13:33'!derivative	|res|	res := Polynom new.	monoms do: [:element | res addMonom: (element derivative)].	^res! !!Polynom methodsFor: 'Ops' stamp: 'Koren 6/11/2024 13:24'!multiplyByMonom: aMonom	(aMonom isKindOf: Monom)		ifFalse: [self error: 'invalid input']		ifTrue:		[			monoms do: [:element | element coef: (element coef * aMonom coef); exp: (element exp + aMonom exp)]		].! !!Polynom methodsFor: 'initialize-release' stamp: 'Koren 6/11/2024 12:26'!initialize	monoms := LinkedList new.! !