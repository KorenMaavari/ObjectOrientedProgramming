Object subclass: #MyObject	instanceVariableNames: 'behavesLike isInterface'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!MyObject methodsFor: 'helpers' stamp: 'Koren 7/19/2024 18:03'!allMethodsUnderstoodByClass: aClass	"Return a Set of all methods that aClass can understand, including those inherited from its superclass(es)."		| methodSet currentClass |		methodSet := Set new.		"Start with the given class."	currentClass := aClass.		"Iterate over the class hierarchy to collect all methods."	[currentClass notNil] whileTrue: [		"Add methods from the current class to the set."		methodSet addAll: currentClass methodDictionary keys.				"Move to the superclass."		currentClass := currentClass superclass.	].	^methodSet! !!MyObject methodsFor: 'helpers' stamp: 'Koren 7/19/2024 17:11'!allSubclassesOf: aClass		| directSubclasses allSubclasses |		"Get direct subclasses of the given class."	directSubclasses := aClass subclasses.		"Initialize a set with direct subclasses."	allSubclasses := Set withAll: directSubclasses.		"Recursively add all subclasses of each direct subclass."	directSubclasses do: [ :eachSubclass |		allSubclasses addAll: (self getSubclassesOf: eachSubclass)	].	^allSubclasses! !!MyObject methodsFor: 'helpers' stamp: 'Koren 7/19/2024 16:42'!getAllDefinedSelectors		^(self selectors)! !!MyObject methodsFor: 'part2' stamp: 'Koren 7/19/2024 18:54'!ambiguities		| totBehaviour tempMethods totalMethods ambMethods |		totBehaviour := self behavesLike.	totalMethods := Set new.	ambMethods := Set new.		"Iterate over all interfaces the class behaves like."	totBehaviour do: [ :interface |		"Get all selectors (methods) from the interface."		tempMethods := interface selectors.				"Check for conflicts by iterating over each method."		tempMethods do: [ :aSelector |			"If the method is already in total methods, it's ambiguous."			(totalMethods includes: aSelector)				ifTrue: [					ambMethods add: aSelector				].						"Add the method to total methods."			totalMethods add: aSelector.		]	].		"Return a sorted collection of ambiguous methods."	^((SortedCollection new) addAll: ambMethods; yourself)! !!MyObject methodsFor: 'part2' stamp: 'Koren 7/18/2024 19:53'!behavesLike		| interfacesSet superclassTemp |		interfacesSet := Set new.		"Add the class's own behavesLike set."	interfacesSet addAll: behavesLike.		"Iterate over superclasses to gather their behavesLikes."	superclassTemp := self superclass.	[superclassTemp ~= MyObject]		whileTrue: [			interfacesSet addAll: (superclassTemp behavesLike).			superclassTemp := superclassTemp superclass.		].		"Recursive add behaviours of all interfaces in behavesLike."	behavesLike do: [ :interface |		(interface ~= self)			ifTrue: [				interfacesSet addAll: (interface behavesLike)			]	].	"If the class is an interface, add itself."	(isInterface = true)		ifTrue: [			interfacesSet add: self		].		^interfacesSet! !!MyObject methodsFor: 'part2' stamp: 'Koren 7/21/2024 17:23'!compile: aCode	| indexCR indexLF |		"Check if the class is an interface."	(self isInterface = true)		ifTrue: [			"Find line breaks in the source code."			indexCR := aCode indexOf: Character cr.			indexLF := aCode indexOf: Character lf.			"Throw an error if the source code contains implementations."		((indexCR > 0) or: [indexLF > 0])			ifTrue: [				AssertionFailure signal: 'Interfaces are not allowed to have methods that define behavior!!'			].		].		"Compile the source code."	^self compile: aCode notifying: nil! !!MyObject methodsFor: 'part2' stamp: 'Koren 7/19/2024 18:17'!isImplemented	| interfaceBehaviour interfaceMethods allSubclasses totSize |		"Check for error: the class must be an interface."	(self isInterface = false)		ifTrue: [			AssertionFailure signal: ((self name) copyWithout: $#), ' is not an interface!!'		].		"Get all methods that need to be implemented."	interfaceBehaviour := self behavesLike.	interfaceMethods := Set new.	interfaceBehaviour do: [ :interface |		interfaceMethods addAll: (interface selectors)	].	totSize := interfaceMethods size.		"Get all subclasses of MyObject."	allSubclasses := self allSubclassesOf: MyObject.		"Check if any subclass implements the interface."	allSubclasses do: [ :aClass |		(aClass isInterface = false)			ifTrue: [				| tempAllMethods tempBehaviour tempCount |				"Check if the class behaves like the current interface."				tempBehaviour := aClass behavesLike.				(tempBehaviour includes: self)					ifTrue: [						"Check if all interface methods are implemented in the class."						tempCount := 0.						tempAllMethods := self allMethodsUnderstoodByClass: aClass.						interfaceMethods do: [ :aMethod |							(tempAllMethods includes: aMethod)								ifTrue: [									tempCount := tempCount + 1								]						].					(tempCount >= totSize)						ifTrue: [							^true						]					]			]	].	"Return false if no subclass implements the interface."	^false! !!MyObject methodsFor: 'part2' stamp: 'Koren 7/18/2024 18:08'!isInterface	^isInterface! !!MyObject methodsFor: 'part2' stamp: 'Koren 7/21/2024 16:46'!new	(isInterface = true)		ifTrue: [			AssertionFailure signal: 'Interfaces can not be instantiated!!'		].		"Create a new instance of the class."	^self basicNew initialize! !!MyObject methodsFor: 'part2' stamp: 'Koren 7/18/2024 18:54'!subclass: aSubclassName instanceVariableNames: instVarNames classVariableNames: classVarNames poolDictionaries: poolDictionaries category: aCategoryName	^self subclass: aSubclassName isInterface: false behavesLike: #() instanceVariableNames: instVarNames classVariableNames: classVarNames poolDictionaries: poolDictionaries category: aCategoryName! !!MyObject methodsFor: 'part2' stamp: 'Koren 7/18/2024 18:47'!subclass: aSubclassName isInterface: isInterfaceVar behavesLike: aCollection instanceVariableNames: instVarNames classVariableNames: classVarNames poolDictionaries: poolDictionaries category: aCategoryName	| subClass |	"Check for error #2.1"	(isInterfaceVar = true and: [self ~= MyObject])		ifTrue: [			AssertionFailure signal: 'Interfaces must derive from MyObject!!'		].		"Check for error #2.2"	(isInterfaceVar = true and: [(instVarNames ~= '') or: [instVarNames ~= ' ']])		ifTrue: [			AssertionFailure signal: 'Interfaces can not have state!!'		].		"Check for error #2.3"	(isInterfaceVar = false and: [isInterface = true])		ifTrue: [			AssertionFailure signal: 'Classes can not derive from an interface!!'		].		"Check for error #2.4"	aCollection do: [ :element |		(element isInterface = false)			ifTrue: [				AssertionFailure signal: 'Can not behave like a non-interface!!'			]	].	"Create the new subclass."	subClass:=(ClassBuilder new)		superclass: self		subclass: aSubclassName		instanceVariableNames: instVarNames		classVariableNames: (classVarNames)		poolDictionaries: poolDictionaries		category: aCategoryName.			"Initialize the new subclass with interface and behaviour settings."		((subClass) instVarNamed:'isInterface' put: isInterfaceVar ).		((subClass) instVarNamed:'behavesLike' put: aCollection ).	^subClass! !!MyObject methodsFor: 'part1' stamp: 'Koren 7/18/2024 13:52'!compile: aSourceCode where: anOrderedCollection	"Compiles the source code with given type constraints. Throws an AssertionFailure if the number of arguments does not match the number of constraints or if there is a type mismatch for any argument."		| funcName funcLocalVars funcImpl injectChecks line1index line2index newMethod arrayOfFuncArgs |		"First, break down the source code into its parts: name, variables, implementation."	line1index := aSourceCode indexOf: (Character cr).		"Check if there are no local variables."	(line1index = 0)		ifTrue: [			"No local variables, break down differently."			funcName := aSourceCode.			funcImpl := ''.			funcLocalVars := ''.		]		ifFalse: [			"Extract the variables and implementation."			funcName := aSourceCode copyFrom: 1 to: (line1index-1). "some_declaration:argA... cr"				"Extract the argument names from the function name."			arrayOfFuncArgs := (funcName findTokens: ':') collect: [ :each |				| words firstWord |				words := each subStrings: ' '.				firstWord := words isEmpty ifFalse: [words first].				firstWord			].				"Check if the number of arguments matches the number of constrains."			((arrayOfFuncArgs size) = (anOrderedCollection size)) ifFalse: [				AssertionFailure signal: 'Can not compile method, number of arguments is not equal to the number of constraints!!'			].				"Inject the argument type checks."			injectChecks := String new.			arrayOfFuncArgs withIndexDo: [ :argName :index |				| argType |				argType := anOrderedCollection at: index.				argType ifNotNil: [					injectChecks := injectChecks, '(', argName, ' isKindOf: ', (argType asString), ') ifFalse: [						AssertionFailure signal: ''Type mismatch!! Argument ', (index asString), ' should be ', (argType asString), '					]'				]			].				"Check if there are local variables."			(line1index+1 = '|')					ifTrue: [					"Extract the local variables"					line2index := aSourceCode indexOf: (Character cr) startingAt: (line1index+1).					funcLocalVars := aSourceCode copyFrom: (line1index+1) to: (line2index-1). "| var1... |cr"					funcImpl := aSourceCode copyFrom: (line2index+1) to: (aSourceCode size).				]				ifFalse: [					"No local variables."					funcImpl := aSourceCode copyFrom: (line1index+1) to: (aSourceCode size).				].		].		"Construct the new method string."	newMethod := funcName, funcLocalVars, injectChecks, funcImpl.		"Compile the new method with injected type checks."	^self compile: newMethod! !