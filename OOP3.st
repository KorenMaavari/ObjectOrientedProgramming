Object subclass: #MyObject	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!MyObject methodsFor: 'part1' stamp: 'Koren 7/13/2024 20:00'!compile: aSourceCode where: anOrderedCollection	| funcName funcLocalVars funcImpl injectChecks line1index line2index newMethod arrayOfFuncArgs |	line1index := aSourceCode indexOf: (Character cr).	(line1index = 0)		ifTrue: [			funcName := aSourceCode.			funcImpl := ''.			funcLocalVars := ''.		]		ifFalse: [			funcName := aSourceCode copyFrom: 1 to: (line1index-1).				"Extract the argument names from the function name."			arrayOfFuncArgs := (funcName findTokens: ':') collect: [ :each |				| words firstWord |				words := each subStrings: ' '.				firstWord := words isEmpty ifFalse: [words first].				firstWord			].				"Check if the number of arguments matches the number of constrains."			((arrayOfFuncArgs size) = (anOrderedCollection size)) ifFalse: [				AssertionFailure signal: 'Can not compile method, number of arguments is not equal to the number of constraints!!'			].				"Inject the argument type checks."			injectChecks := String new.			arrayOfFuncArgs withIndexDo: [ :argName :index |				| argType |				argType := anOrderedCollection at: index.				argType ifNotNil: [					injectChecks := injectChecks, '(', argName, ' isKindOf: ', (argType asString), ') ifFalse: [						AssertionFailure signal: ''Type mismatch!! Argument ', (index asString), ' should be ', (argType asString), '					]'				]			].				"Check if there are local variables."			(line1index+1 = '|')					ifTrue: [					"Extract the local variables"					line2index := aSourceCode indexOf: (Character cr) startingAt: (line1index+1).					funcLocalVars := aSourceCode copyFrom: (line1index+1) to: (line2index-1).					funcImpl := aSourceCode copyFrom: (line2index+1) to: (aSourceCode size).				]				ifFalse: [					"No local variables."					funcImpl := aSourceCode copyFrom: (line1index+1) to: (aSourceCode size).				].		].		"Construct the new method string."	newMethod := funcName, funcLocalVars, injectChecks, funcImpl.		"Compile the new method with injected type checks."	^self compile: newMethod! !