Object subclass: #MyObject	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!MyObject class	instanceVariableNames: 'behavesLike isInterface'!!MyObject class methodsFor: 'part2' stamp: 'Koren 7/21/2024 23:43'!ambiguities		| totBehaviour tempMethods totalMethods ambMethods |		totBehaviour := self behavesLike.	totalMethods := Set new.	ambMethods := Set new.		"Iterate over all interfaces the class behaves like."	totBehaviour do: [ :interface |		"Get all selectors (methods) from the interface."		tempMethods := interface getAllDefinedSelectors.				"Check for conflicts by iterating over each method."		tempMethods do: [ :aSelector |			"If the method is already in total methods, it's ambiguous."			(totalMethods includes: aSelector)				ifTrue: [					ambMethods add: aSelector				].						"Add the method to total methods."			totalMethods add: aSelector.		]	].		"Return a sorted collection of ambiguous methods."	^((SortedCollection new) addAll: ambMethods; yourself)! !!MyObject class methodsFor: 'part2' stamp: 'Koren 7/21/2024 23:48'!behavesLike		| interfacesSet superclassTemp |		interfacesSet := Set new.		"Add the class's own behavesLike set."	interfacesSet addAll: behavesLike.		"Iterate over superclasses to gather their behavesLikes."	superclassTemp := self superclass.	[superclassTemp ~= MyObject]		whileTrue: [			interfacesSet addAll: (superclassTemp behavesLike).			superclassTemp := superclassTemp superclass.		].		"Recursive add behaviours of all interfaces in behavesLike."	behavesLike do: [ :interface |		(interface ~= self)			ifTrue: [				interfacesSet addAll: (interface behavesLike)			].	].	"If the class is an interface, add itself."	(isInterface = true)		ifTrue: [			interfacesSet add: self		].		^interfacesSet! !!MyObject class methodsFor: 'part2' stamp: 'Koren 7/21/2024 19:01'!compile: aCode	| indexCR indexLF |		"Check if the class is an interface."	(self isInterface = true)		ifTrue: [			"Find line breaks in the source code."			indexCR := aCode indexOf: Character cr.			indexLF := aCode indexOf: Character lf.			"Throw an error if the source code contains implementations."		((indexCR > 0) or: [indexLF > 0])			ifTrue: [				AssertionFailure signal: 'Interfaces are not allowed to have methods that define behavior!!'			].		].		"Compile the source code."	^self compile: aCode notifying: nil! !!MyObject class methodsFor: 'part2' stamp: 'Koren 7/21/2024 23:52'!isImplemented	| interfaceBehaviour interfaceMethods allSubclasses totSize |		"Check for error: the class must be an interface."	(self isInterface = false)		ifTrue: [			AssertionFailure signal: ((self name) copyWithout: $#), ' is not an interface!!'		].		"Get all methods that need to be implemented."	interfaceBehaviour := self behavesLike.	interfaceMethods := Set new.	interfaceBehaviour do: [ :interface |		interfaceMethods addAll: (interface getAllDefinedSelectors)	].	totSize := interfaceMethods size.		"Get all subclasses of MyObject."	allSubclasses := self allSubclassesOf: MyObject.		"Check if any subclass implements the interface."	allSubclasses do: [ :aClass |		(aClass isInterface = false)			ifTrue: [				| tempAllMethods tempBehaviour tempCount |				"Check if the class behaves like the current interface."				tempBehaviour := aClass behavesLike.				(tempBehaviour includes: self)					ifTrue: [						"Check if all interface methods are implemented in the class."						tempCount := 0.						tempAllMethods := self allMethodsUnderstoodByClass: aClass.						interfaceMethods do: [ :aMethod |							(tempAllMethods includes: aMethod)								ifTrue: [									tempCount := tempCount + 1								]						].					(tempCount = totSize)						ifTrue: [							^true						].					]			]	].	"Return false if no subclass implements the interface."	^false! !!MyObject class methodsFor: 'part2' stamp: 'Koren 7/21/2024 19:01'!isInterface	^isInterface! !!MyObject class methodsFor: 'part2' stamp: 'Koren 7/21/2024 19:02'!new	(isInterface = true)		ifTrue: [			AssertionFailure signal: 'Interfaces can not be instantiated!!'		].		"Create a new instance of the class."	^self basicNew initialize! !!MyObject class methodsFor: 'part2' stamp: 'Koren 7/21/2024 19:09'!subclass: aSubclassName instanceVariableNames: instVarNames classVariableNames: classVarNames poolDictionaries: poolDictionaries category: aCategoryName	^self subclass: aSubclassName isInterface: false behavesLike: (Array new) instanceVariableNames: instVarNames classVariableNames: classVarNames poolDictionaries: poolDictionaries category: aCategoryName! !!MyObject class methodsFor: 'part2' stamp: 'Koren 7/21/2024 19:11'!subclass: aSubclassName isInterface: isInterfaceVar behavesLike: aCollection instanceVariableNames: instVarNames classVariableNames: classVarNames poolDictionaries: poolDictionaries category: aCategoryName	| subClass |	"Check for error #2.1"	(isInterfaceVar = true and: [self ~= MyObject])		ifTrue: [			AssertionFailure signal: 'Interfaces must derive from MyObject!!'		].		"Check for error #2.2"	(isInterfaceVar = true and: [instVarNames ~= ''])		ifTrue: [			AssertionFailure signal: 'Interfaces can not have state!!'		].		"Check for error #2.3"	(isInterfaceVar = false and: [isInterface = true])		ifTrue: [			AssertionFailure signal: 'Classes can not derive from an interface!!'		].		"Check for error #2.4"	aCollection do: [ :element |		(element isInterface = false)			ifTrue: [				AssertionFailure signal: 'Can not behave like a non-interface!!'			]	].	"Create the new subclass."	subClass:=(ClassBuilder new)		superclass: self		subclass: aSubclassName		instanceVariableNames: instVarNames		classVariableNames: (classVarNames)		poolDictionaries: poolDictionaries		category: aCategoryName.			"Initialize the new subclass with interface and behaviour settings."		((subClass) instVarNamed:'isInterface' put: isInterfaceVar ).		((subClass) instVarNamed:'behavesLike' put: aCollection ).	^subClass! !!MyObject class methodsFor: 'part1' stamp: 'Koren 7/21/2024 23:22'!compile: aSourceCode where: anOrderedCollection    | funcName funcVars funcImpl injectChecks line1Indx line2Indx newMethod arrayOfFuncArgs hasVars |    "First, we need to break down the source code into parts: function name, variables, and implementation."        "Find the index of the first occurrence of the '|' character, indicating the start of local variables."    line1Indx := aSourceCode indexOf: ($|) startingAt: 1.        "If there are local variables, process them accordingly."    (line1Indx = 0) ifFalse: [        "Find the end index of the local variables section."        line2Indx := aSourceCode indexOf: ($|) startingAt: (line1Indx + 1).                "Extract the local variables part, including the surrounding '| ... |'."        funcVars := aSourceCode copyFrom: (line1Indx) to: (line2Indx + 1). "Example: '| var1... |\n'"                "Extract the implementation part of the method."        funcImpl := aSourceCode copyFrom: (line2Indx + 2) to: (aSourceCode size).                "Extract the function name and arguments part."        funcName := aSourceCode copyFrom: 1 to: (line1Indx - 1). "Example: 'some_declaration:argA... \n'"                "Indicate that the method has local variables."        hasVars := true    ] ifTrue: [        "If there are no local variables, break down the source code differently."                "Find the index of the first occurrence of a line break (CR or LF)."        line1Indx := aSourceCode indexOf: (Character cr) startingAt: 1.        (line1Indx = 0) ifTrue: [            line1Indx := aSourceCode indexOf: (Character lf) startingAt: 1.        ].                "If no line break is found, the entire code is considered the function name and arguments."        (line1Indx = 0) ifTrue: [            funcName := aSourceCode.            funcImpl := ''.            funcVars := ''        ] ifFalse: [            "If a line break is found, separate the function name and implementation."            funcImpl := aSourceCode copyFrom: (line1Indx + 1) to: (aSourceCode size).            funcVars := ''.            funcName := aSourceCode copyFrom: 1 to: (line1Indx - 1). "Example: 'some_declaration:argA... \n'"        ].                "Indicate that the method does not have local variables."        hasVars := false    ].        "Extract the argument names from the function name."    arrayOfFuncArgs := (funcName findTokens: ':') collect: [:each |        | words firstWord |        "Split each part by spaces and take the first word."        words := each subStrings: ' '.        firstWord := words isEmpty ifTrue: [nil] ifFalse: [words first].        firstWord    ].        "Remove any nil entries from the list of arguments."    arrayOfFuncArgs := arrayOfFuncArgs select: [:each | each notNil].        "Remove the first element as it is not an argument."    arrayOfFuncArgs := arrayOfFuncArgs allButFirst.        "Check if the number of arguments matches the number of constraints."    ((arrayOfFuncArgs size) = (anOrderedCollection size)) ifFalse: [        AssertionFailure signal: 'Can not compile method, number of arguments is not equal to the number of constraints!!'    ].        "Prepare to inject the argument type checks."    injectChecks := String new.        "Iterate over each argument and its corresponding constraint."    arrayOfFuncArgs withIndexDo: [:argName :index |        | argType |        "Retrieve the type constraint for the current argument."        argType := anOrderedCollection at: index.        argType ifNotNil: [            "Inject the type check for the current argument."            injectChecks := injectChecks , '(', argName , ' isKindOf: ', ((argType name) copyWithout: $#) , ') ifFalse: [ AssertionFailure signal: ''Type mismatch!! Argument ', index printString , ' should be ', ((argType name) copyWithout: $#) , '''].' , String cr.        ]    ].        "Construct the new method string with injected type checks."    newMethod := funcName , funcVars , injectChecks , funcImpl.        "Print the new method for debugging purposes."    "Transcript show: newMethod."        "Compile the new method with the injected type checks."    ^self compile: newMethod.! !!MyObject class methodsFor: 'helpers' stamp: 'Koren 7/21/2024 23:42'!allMethodsUnderstoodByClass: aClass	"Return a Set of all methods that aClass can understand, including those inherited from its superclass(es)."		| methodSet currentClass |		methodSet := Set new.		"Start with the given class."	currentClass := aClass.		"Iterate over the class hierarchy to collect all methods."	[currentClass notNil] whileTrue: [		"Add methods from the current class to the set."		methodSet addAll: currentClass methodDict keys.				"Move to the superclass."		currentClass := currentClass superclass.	].	^methodSet! !!MyObject class methodsFor: 'helpers' stamp: 'Koren 7/21/2024 18:59'!allSubclassesOf: aClass		| directSubclasses allSubclasses |		"Get direct subclasses of the given class."	directSubclasses := aClass subclasses.		"Initialize a set with direct subclasses."	allSubclasses := Set withAll: directSubclasses.		"Recursively add all subclasses of each direct subclass."	directSubclasses do: [ :eachSubclass |		allSubclasses addAll: (self getSubclassesOf: eachSubclass)	].	^allSubclasses! !!MyObject class methodsFor: 'helpers' stamp: 'Koren 7/21/2024 18:59'!getAllDefinedSelectors		^(self selectors)! !MyObject subclass: #Interface1	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Interface1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface1Function! !!Interface1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!randomname_1! !MyObject subclass: #Interface2	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Interface2 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface2Function! !!Interface2 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface2FunctionSpeical! !!Interface2 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!disaster! !!Interface2 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!randomname! !MyObject subclass: #Interface3	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Interface3 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface3Function! !!Interface3 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!lolo! !MyObject subclass: #Interface4	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Interface4 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface4Function! !!Interface4 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!disaster! !MyObject subclass: #Interface5	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Interface5 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface5Function! !!Interface5 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!a! !!Interface5 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!ab! !!Interface5 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo! !!Interface5 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo: arg1! !!Interface5 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo: arg2 baz: arg3! !MyObject subclass: #Interface6	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Interface6 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface6Function! !!Interface6 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!a! !!Interface6 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!ab! !!Interface6 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo! !!Interface6 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo: arg1! !!Interface6 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo: arg2 baz: arg3! !!Interface6 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!lolo! !MyObject subclass: #Object1	instanceVariableNames: 'a b'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Object1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface2Function	                               ^2.! !!Object1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface2FunctionSpeical							|temp |	                               temp := 1 + 2.						^temp.! !!Object1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface3Function	                               ^2.! !!Object1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!disaster							^self! !!Object1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!lolo							^self! !!Object1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!noArgs1	                               ^2.! !!Object1 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!randomname							^self! !Object1 subclass: #Object2	instanceVariableNames: 'c d'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Object2 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface5Function						| temp |	                               temp := 2.						^(temp+temp).! !!Object2 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!noArgs2						| temp |	                               temp := 2.						^(temp+temp).! !Object2 subclass: #Object3	instanceVariableNames: 'e'	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Object3 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!Interface6Function						| temp |	                               temp := 2.						^(temp+temp).! !!Object3 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!noArgs3						| temp |	                               temp := 2.						^(temp+temp).! !!Object3 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!testMethod: aNumber	                                | tempVar |(aNumber	 isKindOf: Number) ifFalse: [ AssertionFailure signal: 'Type mismatch!! Argument 1 should be Number'].	                                tempVar := aNumber + 1. ^tempVar.! !!Object3 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!testMethod: aNumber anotherArg: aString	                                | tempVar |(aNumber isKindOf: Number) ifFalse: [ AssertionFailure signal: 'Type mismatch!! Argument 1 should be Number'].(aString	 isKindOf: String) ifFalse: [ AssertionFailure signal: 'Type mismatch!! Argument 2 should be String'].	                                tempVar := aNumber + 1. ^tempVar.! !Object3 subclass: #Object4	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'OOP3'!!Object4 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!a								^self! !!Object4 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!ab								^self! !!Object4 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo								^self! !!Object4 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo: arg1							^self! !!Object4 methodsFor: 'as yet unclassified' stamp: 'Koren 7/21/2024 23:53'!foo: arg2 baz: arg3								^self! !!Object4 methodsFor: